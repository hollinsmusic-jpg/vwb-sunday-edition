{
  "name": "vwb",
  "version": "1.0.0",
  "description": "VWB Virtual Worship Band – Sunday Edition",
  "main": "main.js",
  "author": "Hollins Musical Productions International",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.hmpi.vwb",
    "productName": "VWB",
    "copyright": "© 2025 Hollins Musical Productions International",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/icon.icns"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  }
}
